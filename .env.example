# Supabase (PostgreSQL) Connection
# Transaction mode (used by Prisma)
DATABASE_URL="postgres://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session mode (used for direct migrations)
DIRECT_URL="postgres://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# Next Auth (Optional but recommended)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
